{
    "name": "@focus-mcp/brick-knowledge",
    "version": "1.1.0",
    "private": false,
    "description": "Knowledge base — index documents, search by content, fetch entries, purge stale data, rank by relevance.",
    "license": "MIT",
    "type": "module",
    "main": "./dist/index.js",
    "exports": {
        ".": "./dist/index.js",
        "./mcp-brick.json": "./mcp-brick.json"
    },
    "files": [
