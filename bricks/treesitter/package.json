{
    "name": "@focus-mcp/brick-treesitter",
    "version": "1.1.1",
    "private": false,
    "description": "Regex-based code indexer for TypeScript/JavaScript — parses symbols, imports, exports.",
    "license": "MIT",
    "type": "module",
    "main": "./dist/index.js",
    "exports": {
        ".": "./dist/index.js",
        "./mcp-brick.json": "./mcp-brick.json"
    },
    "files": [
        "dist",
        "mcp-brick.json",
        "mcp-brick.json.license",
        "README.md"
    ],
    "scripts": {
        "test": "vitest run",
        "build": "tsc -p tsconfig.json"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org"
    },
    "keywords": [
        "mcp",
        "model-context-protocol",
        "ai",
        "llm",
        "focus",
        "brick",
        "ast",
        "parser",
        "symbols",
        "typescript"
    ],
    "author": "FocusMCP contributors",
    "homepage": "https://github.com/focus-mcp/marketplace/tree/main/bricks/treesitter#readme",
    "bugs": {
        "url": "https://github.com/focus-mcp/marketplace/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/focus-mcp/marketplace.git",
        "directory": "bricks/treesitter"
    },
    "peerDependencies": {
        "@focus-mcp/core": "^1.0.0"
    },
    "peerDependenciesMeta": {
        "@focus-mcp/core": {
            "optional": true
        }
    },
    "types": "./dist/index.d.ts"
}
