{
    "name": "@focusmcp/marketplace-root",
    "version": "0.0.0",
    "private": true,
    "description": "FocusMCP — catalogue officiel de briques MCP atomiques",
    "license": "MIT",
    "type": "module",
    "engines": {
        "node": ">=22.0.0",
        "pnpm": ">=10.0.0"
    },
    "packageManager": "pnpm@10.32.1",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/focus-mcp/marketplace.git"
    },
    "homepage": "https://focusmcp.dev",
    "bugs": {
        "url": "https://github.com/focus-mcp/marketplace/issues"
    },
    "scripts": {
        "build": "pnpm -r --filter \"./bricks/**\" --filter \"./modules/**\" --if-present build",
        "build:catalog": "tsx scripts/build-catalog.ts && cp dist/catalog.json publish/catalog.json && cp dist/bricks.md publish/bricks.md",
        "build:docs": "tsx scripts/build-docs.ts",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "format": "biome format --write .",
        "typecheck": "pnpm -r --if-present typecheck && tsc --noEmit",
        "test": "vitest run --config config/vitest.config.ts",
        "test:watch": "vitest --config config/vitest.config.ts",
        "test:coverage": "vitest run --coverage --config config/vitest.config.ts",
        "reuse": "reuse lint",
        "changeset": "changeset",
        "version": "changeset version",
        "release": "changeset publish",
        "prepare": "husky"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.2.0",
        "@changesets/cli": "^2.27.0",
        "@commitlint/cli": "^19.6.0",
        "@commitlint/config-conventional": "^19.6.0",
        "@commitlint/types": "^19.8.1",
        "@types/node": "^22.10.0",
        "@vitest/coverage-v8": "^3.2.0",
        "ajv": "^8.17.1",
        "ajv-formats": "^3.0.1",
        "husky": "^9.1.0",
        "lint-staged": "^15.2.0",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0",
        "vitest": "^3.2.0"
    },
    "pnpm": {
        "overrides": {
            "tar": "^7.5.13",
            "glob": "^10.4.5",
            "minimatch": "^9.0.5",
            "cookie": ">=0.7.0"
        }
    }
}
