{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://focus-mcp.github.io/marketplace/schemas/catalog/v1.json",
  "title": "FocusMCP Marketplace Catalog",
  "description": "Catalogue officiel des briques MCP FocusMCP. Format généré par CI depuis les manifestes bricks/<name>/mcp-brick.json et external_bricks.json.",
  "type": "object",
  "required": ["name", "description", "owner", "updated", "bricks"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "object",
      "required": ["name", "url"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" },
        "email": { "type": "string", "format": "email" }
      }
    },
    "updated": {
      "type": "string",
      "format": "date-time"
    },
    "bricks": {
      "type": "array",
      "items": { "$ref": "#/$defs/brick" }
    }
  },
  "$defs": {
    "brick": {
      "type": "object",
      "required": ["name", "version", "description", "dependencies", "tools", "source"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Nom kebab-case de la brique (sans préfixe 'focus-')."
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$",
          "description": "Version semver de la brique."
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Liste des briques requises (noms, sans préfixe)."
        },
        "tools": {
          "type": "array",
          "items": { "$ref": "#/$defs/tool" }
        },
        "source": { "$ref": "#/$defs/source" },
        "tarballUrl": {
          "type": "string",
          "format": "uri"
        },
        "integrity": {
          "type": "string",
          "pattern": "^(sha256-[A-Za-z0-9+/=]+|[a-f0-9]{64})$",
          "description": "SRI (sha256-...) ou hex sha256."
        },
        "publishedAt": {
          "type": "string",
          "format": "date-time"
        },
        "license": { "type": "string", "minLength": 1 },
        "homepage": { "type": "string", "format": "uri" },
        "publisher": { "type": "string", "minLength": 1 }
      }
    },
    "tool": {
      "type": "object",
      "required": ["name", "description", "inputSchema"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "inputSchema": {
          "type": "object",
          "description": "JSON Schema (Draft 2020-12) de l'input du tool."
        }
      }
    },
    "source": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "path"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "local" },
            "path": { "type": "string", "minLength": 1 }
          }
        },
        {
          "type": "object",
          "required": ["type", "url"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "url" },
            "url": { "type": "string", "format": "uri" },
            "sha": {
              "type": "string",
              "pattern": "^(sha256-[A-Za-z0-9+/=]+|[a-f0-9]{64})$"
            }
          }
        },
        {
          "type": "object",
          "required": ["type", "url", "path", "ref"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "git-subdir" },
            "url": { "type": "string", "format": "uri" },
            "path": { "type": "string", "minLength": 1 },
            "ref": { "type": "string", "minLength": 1 }
          }
        }
      ]
    }
  }
}
